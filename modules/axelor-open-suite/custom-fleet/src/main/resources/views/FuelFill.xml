<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views
  https://axelor.com/xml/ns/object-views/object-views_8.5.xsd">

  <grid name="fuel-fill-grid" title="Fuel Fills" model="com.custom.fleet.db.FuelFill">
    <field name="trip"/>
    <field name="fillDate"/>
    <field name="product"/>
    <field name="stockLocation"/>
    <field name="qty"/>
  </grid>

  <form name="fuel-fill-form" title="Fuel Fill" model="com.custom.fleet.db.FuelFill"
    onSave="action-fuel-fill-create-stock-move">

    <panel title="Fuel Consumption">
      <field name="trip" hidden="true"/>
      <field name="fillDate"/>
      <field name="product"/>
      <field name="stockLocation"/>
      <field name="qty"/>
      <field name="notes"/>
    </panel>
  </form>


</object-views>