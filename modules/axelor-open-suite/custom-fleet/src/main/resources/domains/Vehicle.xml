<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models
  https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

  <module name="fleet" package="com.custom.fleet.db"/>

  <entity name="Vehicle">
    <string name="licensePlate" required="true" help="Unique ID of the vehicle"/>
    <string name="modelName" required="true"/>
    <integer name="year"/>
    <decimal name="capacityKg" title="Capacity (KG)"/>
    <integer name="status" selection="fleet.vehicle.status.selection" default="1"/>
    <many-to-one name="mainDriver" ref="com.custom.fleet.db.Driver" title="Driver"/>
  </entity>

</domain-models>